% 			\end{beamercolorbox}%
% 			\begin{beamercolorbox}[%
% 					wd=0.50\paperwidth, ht=2.5ex, dp=1.5ex, leftskip=0.8em, rightskip=0.8em]{footline right}%
% 				\usebeamerfont{footline}\insertshortauthor\hfill\insertframenumber/\inserttotalframenumber%
% 			\end{beamercolorbox}%
% 		}%
% 	\fi
% }
%
% --------------------------------------------------------------------------
% Separation line below frametitle
% --------------------------------------------------------------------------
\setbeamertemplate{frametitle continuation}{}

% Draw a thin navy rule below the frametitle area
\addtobeamertemplate{frametitle}{}{%
	\vspace{0.3em}%
	{\color{umichNavy}\hrule height 0.4pt}%
	\vspace{0.3em}%
}

\mode<all>
